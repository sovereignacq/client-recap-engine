# Supabase (public — safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY

# Supabase (server-only — NEVER expose to the browser; used by Stripe webhook)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Stripe (server-only)
# Test mode: sk_test_..., live mode: sk_live_...
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
# Set after creating your webhook endpoint in the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET
# Price IDs created in the Stripe dashboard
STRIPE_PRICE_PRO_MONTHLY=price_YOUR_MONTHLY_ID
STRIPE_PRICE_PRO_ANNUAL=price_YOUR_ANNUAL_ID

# Resend (transactional email — server-only)
# Create at https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_KEY
# Optional: until you verify a domain, leave unset and emails will send from
# the Resend sandbox sender (onboarding@resend.dev), which only delivers to
# the address you signed up with. After verifying a domain at
# https://resend.com/domains, set this to e.g. "client-recap-engine <hello@yourdomain.com>"
RESEND_FROM_EMAIL=

# Public app URL used inside transactional email links
NEXT_PUBLIC_APP_URL=https://client-recap-engine.vercel.app

# Gemini (AI recap generation — server-only)
# Create at https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_KEY
